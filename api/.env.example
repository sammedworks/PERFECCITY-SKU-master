# Copy to .env and adjust values
PERFECCITY_NEO4J_URI=bolt://localhost:7687
PERFECCITY_NEO4J_USER=neo4j
PERFECCITY_NEO4J_PASSWORD=password
PERFECCITY_NEO4J_DATABASE=neo4j
PERFECCITY_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# API key auth — set to protect mutating endpoints (POST/DELETE).
# Leave empty to disable auth (dev mode).
PERFECCITY_API_KEY=
